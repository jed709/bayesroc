title: "Analyzing univariate recognition data with bayesroc"
output: rmarkdown::html_vignette
vignette: >
  %\VignetteIndexEntry{Analyzing univariate recognition data with bayesroc}
  %\VignetteEngine{knitr::rmarkdown}
  %\VignetteEncoding{UTF-8}
